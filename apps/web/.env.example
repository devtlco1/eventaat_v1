# Next.js
NEXT_PUBLIC_APP_NAME=eventaat
# eventaat API (port 3000 by default; web dev runs on 3001)
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:3000"
# When "true", unauthenticated users hitting dashboard shell routes are redirected to /login.
# Default is false so prototype review works without login.
# NEXT_PUBLIC_AUTH_REQUIRED=false
