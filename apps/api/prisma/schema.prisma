// PostgreSQL primary datastore. Phase 0 foundation marker; Phase 2A auth / RBAC / OTP / session / audit.
generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Step 0 marker — retained so existing environments keep a single-row legacy table; harmless alongside auth models.
model FoundationSchemaMarker {
  id Int @id @default(0)

  @@map("foundation_schema_marker")
}

// --- Phase 2A: enums (align with @eventaat/shared `UserRole` and blueprint) ---

enum UserRole {
  customer
  restaurant_owner
  branch_manager
  restaurant_host
  call_center_agent
  call_center_supervisor
  operations_admin
  content_manager
  finance_manager
  super_admin
}

enum UserStatus {
  active
  pending_verification
  suspended
  disabled
}

enum OtpPurpose {
  login
  register
  phone_verification
  staff_invite
}

enum OtpChannel {
  whatsapp
  sms
  manual
}

enum OtpStatus {
  pending
  verified
  expired
  failed
  cancelled
}

enum RoleScopeType {
  platform
  restaurant
  branch
  call_center
}

enum AuditActorType {
  user
  system
  support
}

// --- Phase 3A: restaurant / branch / seating / tables (business scope; no reservation models yet) ---

enum RestaurantStatus {
  draft
  pending_review
  active
  needs_changes
  bookings_disabled
  suspended
  archived
}

enum BranchStatus {
  open
  closed
  temporarily_closed
  bookings_disabled
  archived
}

enum SeatingAreaType {
  indoor
  outdoor
  family
  vip
  smoking
  non_smoking
  mixed
}

enum TableStatus {
  available
  reserved
  occupied
  waiting_cleaning
  cleaning
  blocked
  out_of_service
  archived
}

enum RestaurantUserRole {
  owner
  manager
  host
  viewer
}

enum RestaurantOnboardingStatus {
  not_started
  profile_pending
  branches_pending
  tables_pending
  under_review
  approved
  needs_changes
}

// --- Phase 2A + Phase 3A: core auth models + business restaurant/branch/tables (see `UserRoleAssignment` vs `RestaurantStaffAssignment`) ---

model User {
  id              String     @id @default(cuid())
  phone           String
  phoneNormalized String
  fullName        String?
  city            String?
  status          UserStatus
  primaryRole     UserRole
  isPhoneVerified Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  lastLoginAt     DateTime?
  disabledAt      DateTime?
  suspendedAt     DateTime?

  roleAssignments            UserRoleAssignment[]
  restaurantStaffAssignments RestaurantStaffAssignment[]

  otpChallenges   OtpChallenge[]
  sessions        UserSession[]
  auditLogs       AuditLog[]           @relation("UserAuditLog")

  @@unique([phone])
  @@unique([phoneNormalized])
  @@map("users")
}

/// Scoped roles: platform, restaurant, branch, or call-center pool. `scopeId` empty string = platform-wide when scope is platform; optional entity id otherwise (future FKs).
model UserRoleAssignment {
  id        String        @id @default(cuid())
  userId    String
  role      UserRole
  scopeType RoleScopeType
  scopeId   String        @default("")
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// One active line per (user, role, scope) — `scopeId` default "" for platform; use non-empty ids for entity scopes.
  @@unique([userId, role, scopeType, scopeId])
  @@index([userId, role, scopeType])
  @@index([userId, isActive])
  @@index([scopeType, scopeId])
  @@map("user_role_assignments")
}

/// OTP side — never store raw codes; `codeHash` only.
model OtpChallenge {
  id                String     @id @default(cuid())
  userId            String?
  phone             String
  phoneNormalized   String
  purpose           OtpPurpose
  channel           OtpChannel
  status            OtpStatus
  codeHash          String
  expiresAt         DateTime
  verifiedAt        DateTime?
  failedAt          DateTime?
  attemptCount      Int        @default(0)
  maxAttempts       Int        @default(5)
  providerMessageId String?
  providerStatus    String?
  metadata          Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phoneNormalized])
  @@index([status])
  @@index([purpose])
  @@index([expiresAt])
  @@index([userId])
  @@map("otp_challenges")
}

model UserSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String?
  userAgent        String?
  ipAddress        String?
  revokedAt        DateTime?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("user_sessions")
}

model AuditLog {
  id          String         @id @default(cuid())
  actorUserId String?
  actorType   AuditActorType
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime       @default(now())

  actorUser User? @relation("UserAuditLog", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// --- Phase 3A: persisted restaurant domain (no Reservation model in this phase) ---

/// Restaurant (catalog + operations settings). Mock UI still uses a parallel `RestaurantStatus` vocabulary in `packages/shared`.
model Restaurant {
  id                                String   @id @default(cuid())
  nameAr                            String
  nameEn                            String?
  slug                              String   @unique
  descriptionAr                     String?
  descriptionEn                     String?
  city                              String
  area                              String?
  addressText                       String?
  phone                             String?
  status                            RestaurantStatus
  onboardingStatus                  RestaurantOnboardingStatus
  bookingsEnabled                   Boolean  @default(false)
  isVisible                         Boolean  @default(false)
  cuisineTypes                      String[] @default([])
  tags                              Json?
  ratingAvg                         Decimal? @db.Decimal(4, 2)
  ratingCount                       Int      @default(0)
  cancellationPolicyAr              String?
  defaultReservationDurationMinutes Int      @default(90)
  defaultGracePeriodMinutes         Int      @default(15)
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt
  archivedAt                        DateTime?

  branches          Branch[]
  seatingAreas      SeatingArea[]
  tables            RestaurantTable[]
  staffAssignments  RestaurantStaffAssignment[]

  @@index([status])
  @@index([city, area])
  @@index([bookingsEnabled])
  @@index([isVisible])
  @@map("restaurants")
}

model Branch {
  id            String   @id @default(cuid())
  restaurantId  String
  nameAr        String
  nameEn        String?
  city          String
  area          String
  addressText   String
  landmark      String?
  phone         String?
  status        BranchStatus
  bookingsEnabled Boolean  @default(true)
  defaultHoursAr String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  archivedAt    DateTime?

  restaurant       Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  seatingAreas     SeatingArea[]
  tables           RestaurantTable[]
  staffAssignments RestaurantStaffAssignment[]

  @@index([restaurantId])
  @@index([status])
  @@index([city, area])
  @@index([bookingsEnabled])
  @@map("branches")
}

/// Seating zone (restaurant-level and/or branch-level). Distinct from RBAC `UserRole` scope rows.
model SeatingArea {
  id           String   @id @default(cuid())
  restaurantId String
  branchId     String?
  nameAr       String
  nameEn       String?
  type         SeatingAreaType
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  tables     RestaurantTable[]

  @@index([restaurantId])
  @@index([branchId])
  @@index([type])
  @@index([isActive])
  @@map("seating_areas")
}

model RestaurantTable {
  id             String   @id @default(cuid())
  restaurantId   String
  branchId       String
  seatingAreaId  String?
  tableNumber    String
  displayNameAr  String?
  capacityMin    Int      @default(1)
  capacityMax    Int
  status         TableStatus
  isBookable     Boolean  @default(true)
  sortOrder      Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  archivedAt     DateTime?

  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  seatingArea SeatingArea? @relation(fields: [seatingAreaId], references: [id], onDelete: SetNull)

  @@unique([branchId, tableNumber])
  @@index([restaurantId])
  @@index([branchId])
  @@index([seatingAreaId])
  @@index([status])
  @@index([isBookable])
  @@index([capacityMax])
  @@map("restaurant_tables")
}

/// Per-restaurant/branch **operations** access for a `User`. Does not replace `UserRole` / `UserRoleAssignment` (auth/RBAC).
/// Composite unique includes `branchId`; PostgreSQL treats `NULL` as distinct in unique constraints, so several rows
/// with `branchId = null` can slip through if not enforced in application code — see `docs/restaurant-data-model.md`.
model RestaurantStaffAssignment {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String
  branchId     String?
  role         RestaurantUserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branch     Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([userId, restaurantId, role, branchId])
  @@index([userId])
  @@index([restaurantId])
  @@index([branchId])
  @@index([role])
  @@index([isActive])
  @@map("restaurant_staff_assignments")
}
