# API server (defaults: API_PORT=3000)
API_PORT=3000
PORT=3000

# PostgreSQL — used by Prisma. Local docker-compose (repo root: docker compose up -d postgres):
# postgresql://eventaat:eventaat@localhost:5432/eventaat?schema=public
DATABASE_URL="postgresql://eventaat:eventaat@localhost:5432/eventaat?schema=public"

# Reserved for future OTP, sessions, queues (see blueprint)
REDIS_URL="redis://127.0.0.1:6379"

# --- Phase 2B: JWT + OTP (required for /auth/* routes) ---
# Use a long random secret in production; never commit real secrets.
JWT_ACCESS_SECRET="change-me-min-32-chars-in-production-aaaaaaaa"
# Access token lifetime (e.g. 15m, 1h, 7d)
JWT_ACCESS_EXPIRES_IN="15m"
# Session / refresh window
REFRESH_TOKEN_EXPIRES_DAYS="14"
# OTP challenge
OTP_EXPIRES_MINUTES="5"
OTP_MAX_ATTEMPTS="5"
# If true, response of POST /auth/otp/request may include devOtp (development/test only; never in production)
AUTH_DEV_EXPOSE_OTP="false"
