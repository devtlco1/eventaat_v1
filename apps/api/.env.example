# API server (defaults: API_PORT=3000)
API_PORT=3000
PORT=3000

# PostgreSQL — used by Prisma. Example for docker-compose in repo root:
# postgresql://eventaat:eventaat@localhost:5432/eventaat?schema=public
DATABASE_URL="postgresql://user:pass@localhost:5432/eventaat?schema=public"

# Reserved for future OTP, sessions, queues (see blueprint)
REDIS_URL="redis://127.0.0.1:6379"
